# Backend
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_DATABASE_PASSWORD=database_password_placeholder
SUPABASE_PUBLISHABLE_KEY=public_key_placeholder
# Somente backend Express; nunca frontend, logs ou clientes públicos.
SUPABASE_SERVICE_ROLE_KEY=service_role_key_placeholder
SUPABASE_SECRET_KEY=secret_key_placeholder
SUPABASE_JWKS_URL=https://PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json
CORS_ORIGINS=http://localhost:5173
# Raiz pública do PWA (com barra final), usada como redirectTo do convite por
# e-mail (Fase 11 / ADR 0014). Deve ser a raiz do site, não uma rota
# aninhada — GitHub Pages não faz rewrite de SPA, uma rota aninhada 404 em
# acesso direto.
SITE_URL=http://localhost:5173/

# Frontend build — valores públicos
VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_SUPABASE_URL=https://PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=public_key_placeholder

